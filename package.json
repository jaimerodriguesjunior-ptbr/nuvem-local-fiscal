{
  "name": "nuvem-local-fiscal",
  "version": "0.1.0",
  "private": true,
  "description": "Mock compatível com Nuvem Fiscal para evoluir depois para motor fiscal próprio.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "nfse:toledo:smoke": "tsx scripts/nfse-toledo-homologation-smoke.ts"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "@supabase/supabase-js": "^2.108.1",
    "@types/qrcode": "^1.5.6",
    "@xmldom/xmldom": "^0.9.10",
    "fastify": "^5.3.3",
    "libxmljs2": "^0.37.0",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.4",
    "xml-crypto": "^6.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/node-forge": "^1.3.14",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
